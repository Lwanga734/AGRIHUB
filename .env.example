# ── Vercel (frontend + Node API on same project) ──
# Set these in Vercel → Project → Settings → Environment Variables
VITE_USE_NODE_API=true
VITE_API_URL=
JWT_SECRET=change-this-to-a-long-random-string

# ── Local dev (Node API) ──
# VITE_USE_NODE_API=true
# VITE_API_URL=
# Run: npm.cmd run dev:full

# ── Local dev (PHP / XAMPP) — optional ──
# VITE_USE_NODE_API=false
# VITE_API_URL=http://localhost/agrihub
