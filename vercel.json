{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install && npm install --prefix server/node",
  "framework": "vite",
  "build": {
    "env": {
      "VITE_USE_NODE_API": "true"
    }
  },
  "rewrites": [
    {
      "source": "/(health|auth|produce|prices|transactions|dashboard|users|notifications|profile)(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  }
}
